generator client {
  provider   = "prisma-client"
  output     = "../generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model Artwork {
  id                  String        @id @default(uuid())
  title               String
  artistId            String
  medium              String?
  dimensions          Json? // { width: number, height: number, unit: "cm" | "in" }
  year                String
  mainImageUrl        String?
  additionalImageUrls String[]      @default([])
  certificationUrl    String
  status              ArtworkStatus @default(IN_HOME)
  location            String?
  purchasePrice       Decimal?
  currency            Currency      @default(USD)
  notes               String?

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("artworks")
}

model Artist {
  id          String    @id @default(uuid())
  name        String
  description String?
  artworks    Artwork[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("artists")
}

enum ArtworkStatus {
  IN_HOME
  IN_STORAGE
  ON_LOAN
  IN_EXHIBITION
}

enum Currency {
  USD
  VND
}
